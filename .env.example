# ========== ZYND SDK CONFIGURATION ==========
USE_ZYND=1
ZYND_API_KEY=your_zynd_api_key_here
ZYND_REGISTRY_URL=https://registry.zynd.ai
ZYND_WEBHOOK_HOST=localhost

# Agent Ports (Zynd orchestration)
ORCH_ZYND_PORT=5100
MATCHING_ZYND_PORT=5101
BIAS_ZYND_PORT=5102
SKILL_ZYND_PORT=5103
ATS_ZYND_PORT=5104
PASSPORT_ZYND_PORT=5105
GITHUB_ZYND_PORT=5106
LINKEDIN_ZYND_PORT=5107
LEETCODE_ZYND_PORT=5108
CODEFORCES_ZYND_PORT=5109

# Agent Identity Credentials (VCs)
# These should be paths to the JSON files in the credentials/ directory
ORCH_ZYND_VC=credentials/orchestrator_vc.json
MATCHING_ZYND_VC=credentials/matching_vc.json
BIAS_ZYND_VC=credentials/bias_vc.json
SKILL_ZYND_VC=credentials/skill_vc.json
ATS_ZYND_VC=credentials/ats_vc.json
PASSPORT_ZYND_VC=credentials/passport_vc.json
GITHUB_ZYND_VC=credentials/github_vc.json
LINKEDIN_ZYND_VC=credentials/linkedin_vc.json
LEETCODE_ZYND_VC=credentials/leetcode_vc.json
CODEFORCES_ZYND_VC=credentials/codeforces_vc.json

# ========== DATABASE CONFIGURATION ==========
# IMPORTANT: Set your actual database credentials here - no hardcoded defaults
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/fhn

# ========== BACKEND CONFIGURATION ==========
BACKEND_PORT=8010
SECRET_KEY=your_secret_key_here
ENV=development
CORS_ORIGINS=http://localhost:5173

# ========== AGENT ENDPOINTS (Direct HTTP calls - used when USE_ZYND=0) ==========
# These defaults match agents_services/ ports
MATCHING_SERVICE_URL=http://localhost:8001
BIAS_SERVICE_URL=http://localhost:8002
SKILL_SERVICE_URL=http://localhost:8003
ATS_SERVICE_URL=http://localhost:8004
GITHUB_SERVICE_URL=http://localhost:8005
LEETCODE_SERVICE_URL=http://localhost:8006
LINKEDIN_SERVICE_URL=http://localhost:8007
PASSPORT_SERVICE_URL=http://localhost:8008
JOB_DESCRIPTION_SERVICE_URL=http://localhost:8009
CODEFORCES_SERVICE_URL=http://localhost:8010

# ========== SIGNING KEYS ==========
# Ed25519 keys for credential signing (generate with: python -c "from cryptography.hazmat.primitives.asymmetric.ed25519 import Ed25519PrivateKey; k=Ed25519PrivateKey.generate(); print(k.private_bytes_raw().hex())")
SIGNING_PRIVATE_KEY_B64=
SIGNING_PUBLIC_KEY_B64=

# ========== PASSPORT VERIFICATION ==========
PASSPORT_VERIFY_BASE_URL=https://yourdomain.com
